{
  "name": "robarol-monolith",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:all": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace shared && npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.0"
  }
}
